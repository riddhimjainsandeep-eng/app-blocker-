<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D47A1"
    android:gravity="center"
    android:padding="32dp">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@android:drawable/ic_menu_camera"
        android:layout_marginBottom="32dp"
        android:contentDescription="Study Image Placeholder"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Focus, Riddhim. Your CA Foundation and ISC Board exams are the only things that matter right now."
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="The MacBook Pro is waiting for you in May. Don't trade your future for a 15-second story."
        android:textColor="#BBDEFB"
        android:textSize="18sp"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnBackToStudy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Back to Study"
        android:paddingHorizontal="32dp"
        android:paddingVertical="12dp"
        android:backgroundTint="#FFFFFF"
        android:textColor="#0D47A1"
        android:textSize="18sp"
        android:textStyle="bold"/>

</LinearLayout>
