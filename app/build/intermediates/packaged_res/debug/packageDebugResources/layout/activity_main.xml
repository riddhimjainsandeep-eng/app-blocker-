<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Study Sanctum"
            android:textColor="#C8A2F8"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus Guard"
            android:textColor="#8888AA"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- Enable Service Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SERVICE STATUS"
                android:textColor="#8888AA"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnEnableService"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Enable Focus Guard"
                android:textColor="#0D0D1A"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#C8A2F8"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Block Rules Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADD BLOCK RULES"
                android:textColor="#8888AA"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnAddApp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📱  Add App to Block"
                android:textColor="#C8A2F8"
                android:textSize="15sp"
                android:backgroundTint="#1A1A2E"
                android:stateListAnimator="@null"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnAddWebsite"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🌐  Add Website to Block"
                android:textColor="#A2E8F8"
                android:textSize="15sp"
                android:backgroundTint="#1A1A2E"
                android:stateListAnimator="@null"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btnAddKeyword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔑  Add Keyword to Block"
                android:textColor="#F8D7A2"
                android:textSize="15sp"
                android:backgroundTint="#1A1A2E"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Weekly Report Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WEEKLY PROGRESS REPORT"
                android:textColor="#8888AA"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Get a detailed breakdown of your focus stats, weekly improvement, and distraction patterns — sent directly to your inbox."
                android:textColor="#6666AA"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnSendReport"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📧  Send My Weekly Report"
                android:textColor="#0D0D1A"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#A2E8F8"
                android:stateListAnimator="@null" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
