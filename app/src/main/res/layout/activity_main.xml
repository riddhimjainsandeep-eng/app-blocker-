<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ss_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="48dp">

        <!-- ══ HEADER ═══════════════════════════════════════════════════════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/headerLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnProfileAvatar"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="22dp"
                    app:cardBackgroundColor="@color/ss_primary_dim"
                    app:strokeColor="@color/ss_primary"
                    app:strokeWidth="1dp">
                    <TextView
                        android:id="@+id/tvInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="U"
                        android:textColor="@color/ss_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="StudySanctum"
                        android:textColor="@color/ss_foreground"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distraction-Free Workspace"
                        android:textColor="@color/ss_muted_fg"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/headerShield"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="@color/ss_card"
                app:strokeColor="@color/ss_border"
                app:strokeWidth="1dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🛡️"
                    android:textSize="18sp" />
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <!-- ══ UPDATE BANNER ════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/ss_card"
            app:strokeColor="@color/ss_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🚀 New version available?"
                    android:textColor="@color/ss_muted_fg"
                    android:textSize="13sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCheckUpdate"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Check Now"
                    android:textSize="11sp"
                    android:textColor="@color/ss_background"
                    app:backgroundTint="@color/ss_primary"
                    app:cornerRadius="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ FOCUS MODE CONTROLS ════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/ss_card"
            app:strokeColor="@color/ss_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Strict Mode -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/ss_muted"
                        app:cardElevation="0dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="⚡"
                            android:textSize="16sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Strict Mode"
                            android:textColor="@color/ss_foreground"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Zero tolerance for distractions"
                            android:textColor="@color/ss_muted_fg"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchStrictMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/ss_border"
                    android:layout_marginStart="64dp" />

                <!-- Mental Friction -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_marginEnd="12dp"
                        app:cardCornerRadius="8dp"
                        app:cardBackgroundColor="@color/ss_info_dim"
                        app:cardElevation="0dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🧠"
                            android:textSize="16sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mental Friction"
                            android:textColor="@color/ss_foreground"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Solve puzzles to unlock apps"
                            android:textColor="@color/ss_muted_fg"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchMentalFriction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ ACTIVE BLOCKS ════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIVE BLOCKS"
            android:textColor="@color/ss_muted_fg"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="24dp">
            <LinearLayout
                android:id="@+id/blockedAppsRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <!-- ══ MANAGEMENT ══════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MANAGEMENT"
            android:textColor="@color/ss_muted_fg"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"
            android:layout_marginStart="4dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="@color/ss_card"
            app:strokeColor="@color/ss_border"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="4dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEnableService"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="⚡  Enable Focus Guard"
                    android:textColor="@color/ss_foreground"
                    android:textSize="15sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp"
                    app:iconPadding="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/ss_border"
                    android:layout_marginStart="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddApp"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="📱  Manage Blocked Apps"
                    android:textColor="@color/ss_foreground"
                    android:textSize="15sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/ss_border"
                    android:layout_marginStart="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnManageWhitelist"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="✅  Whitelist Settings"
                    android:textColor="@color/ss_foreground"
                    android:textSize="15sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/ss_border"
                    android:layout_marginStart="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddWebsite"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🌐  Block a Website"
                    android:textColor="@color/ss_foreground"
                    android:textSize="15sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/ss_border"
                    android:layout_marginStart="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddKeyword"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🔑  Block a Keyword"
                    android:textColor="@color/ss_foreground"
                    android:textSize="15sp"
                    android:gravity="start|center_vertical"
                    android:paddingStart="16dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ REPORTS & STATS ════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewStats"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="📊  Insights"
                android:textColor="@color/ss_background"
                android:textSize="14sp"
                android:textStyle="bold"
                app:backgroundTint="@color/ss_primary"
                app:cornerRadius="12dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendReport"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="📧  Report"
                android:textColor="@color/ss_foreground"
                android:textSize="14sp"
                app:backgroundTint="@color/ss_card"
                app:strokeColor="@color/ss_border"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnProtectUninstall"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="🛡️  Protect Against Uninstall"
            android:textColor="@color/ss_foreground"
            android:textSize="14sp"
            app:strokeColor="@color/ss_border"
            app:cornerRadius="12dp" />

    </LinearLayout>
</ScrollView>