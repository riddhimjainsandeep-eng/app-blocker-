<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="96dp">

        <!-- ══ HEADER ═══════════════════════════════════════════════════════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp">

            <!-- Left: Avatar + Title -->
            <LinearLayout
                android:id="@+id/headerLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">

                <FrameLayout
                    android:id="@+id/btnProfileAvatar"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginEnd="12dp">
                    <TextView
                        android:id="@+id/tvInitials"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:gravity="center"
                        android:text="U"
                        android:textColor="#11C27A"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:background="@drawable/circle_avatar_bg" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="StudySanctum"
                        android:textColor="#EEF2F7"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distraction-Free Workspace"
                        android:textColor="#5D7A99"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right: Shield icon -->
            <FrameLayout
                android:id="@+id/headerShield"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/circle_avatar_bg">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🔒"
                    android:textSize="15sp" />
            </FrameLayout>
        </RelativeLayout>

        <!-- ══ CHECK FOR UPDATES BANNER ═══════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/glass_card"
            android:padding="14dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🚀 New version available?"
                android:textColor="#5D7A99"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnCheckUpdate"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Check Now"
                android:textColor="#0B0F1A"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="#11C27A"
                android:stateListAnimator="@null"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />
        </LinearLayout>

        <!-- ══ TOGGLE CARDS ════════════════════════════════════════════════ -->
        <!-- Strict Mode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/glass_card"
            android:padding="18dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <FrameLayout
                android:id="@+id/iconStrictMode"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/icon_bg_muted"
                android:layout_marginEnd="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="⚡"
                    android:textSize="14sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Strict Mode"
                    android:textColor="#EEF2F7"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zero tolerance for distractions"
                    android:textColor="#5D7A99"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchStrictMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#EEF2F7"
                android:trackTint="#1E2D3D" />
        </LinearLayout>

        <!-- Mental Friction Logic -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/glass_card"
            android:padding="18dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <FrameLayout
                android:id="@+id/iconMentalFriction"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/icon_bg_info"
                android:layout_marginEnd="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="🧠"
                    android:textSize="14sp" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mental Friction Logic"
                    android:textColor="#EEF2F7"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solve puzzles to unlock apps"
                    android:textColor="#5D7A99"
                    android:textSize="11sp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switchMentalFriction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#EEF2F7"
                android:trackTint="#1E2D3D" />
        </LinearLayout>

        <!-- ══ ACTIVE BLOCKS SECTION ══════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ACTIVE BLOCKS"
            android:textColor="#5D7A99"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.25"
            android:layout_marginBottom="12dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:id="@+id/blockedAppsRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <!-- ══ MANAGEMENT SECTION ═════════════════════════════════════════ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MANAGE"
            android:textColor="#5D7A99"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.25"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_card"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnEnableService"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="⚡  Enable Focus Guard"
                android:textColor="#EEF2F7"
                android:textSize="14sp"
                android:backgroundTint="@android:color/transparent"
                android:stateListAnimator="@null"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E2D3D"
                android:layout_marginStart="20dp" />

            <Button
                android:id="@+id/btnAddApp"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="📱  Manage Blocked Apps"
                android:textColor="#EEF2F7"
                android:textSize="14sp"
                android:backgroundTint="@android:color/transparent"
                android:stateListAnimator="@null"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E2D3D"
                android:layout_marginStart="20dp" />

            <Button
                android:id="@+id/btnManageWhitelist"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="✅  Whitelist (Study Apps Only)"
                android:textColor="#EEF2F7"
                android:textSize="14sp"
                android:backgroundTint="@android:color/transparent"
                android:stateListAnimator="@null"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E2D3D"
                android:layout_marginStart="20dp" />

            <Button
                android:id="@+id/btnAddWebsite"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🌐  Block a Website"
                android:textColor="#EEF2F7"
                android:textSize="14sp"
                android:backgroundTint="@android:color/transparent"
                android:stateListAnimator="@null"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E2D3D"
                android:layout_marginStart="20dp" />

            <Button
                android:id="@+id/btnAddKeyword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔑  Block a Keyword"
                android:textColor="#EEF2F7"
                android:textSize="14sp"
                android:backgroundTint="@android:color/transparent"
                android:stateListAnimator="@null"
                android:gravity="start|center_vertical"
                android:paddingStart="20dp" />
        </LinearLayout>

        <!-- ══ REPORTS & STATS ════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnViewStats"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="📊  Insights"
                android:textColor="#0B0F1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="#11C27A"
                android:stateListAnimator="@null"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSendReport"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="📧  Weekly Report"
                android:textColor="#EEF2F7"
                android:textSize="14sp"
                android:backgroundTint="#1A2233"
                android:stateListAnimator="@null"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnProtectUninstall"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🛡️  Protect Against Uninstall"
            android:textColor="#EEF2F7"
            android:textSize="14sp"
            android:backgroundTint="#16202E"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>
