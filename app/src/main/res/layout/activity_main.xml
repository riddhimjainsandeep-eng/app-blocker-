<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Study Sanctum"
            android:textColor="#C8A2F8"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Focus Guard"
            android:textColor="#8888AA"
            android:textSize="14sp"
            android:layout_marginBottom="32dp" />

        <!-- Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SERVICE STATUS"
                android:textColor="#8888AA"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnEnableService"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Enable Focus Guard"
                android:textColor="#0D0D1A"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#C8A2F8"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Block Apps Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BLOCKED APPS"
                android:textColor="#8888AA"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnAddApp"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="+ Add App Package"
                android:textColor="#C8A2F8"
                android:textSize="14sp"
                android:backgroundTint="#1A1A2E"
                android:strokeColor="#C8A2F8"
                android:stateListAnimator="@null"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvAppsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No apps blocked yet."
                android:textColor="#555577"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Block Websites Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BLOCKED WEBSITES"
                android:textColor="#8888AA"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnAddWebsite"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="+ Add Website Domain"
                android:textColor="#A2E8F8"
                android:textSize="14sp"
                android:backgroundTint="#1A1A2E"
                android:stateListAnimator="@null"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvWebsitesList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No websites blocked yet."
                android:textColor="#555577"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Block Keywords Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BLOCKED KEYWORDS"
                android:textColor="#8888AA"
                android:textSize="11sp"
                android:letterSpacing="0.15"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnAddKeyword"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="+ Add Keyword"
                android:textColor="#F8D7A2"
                android:textSize="14sp"
                android:backgroundTint="#1A1A2E"
                android:stateListAnimator="@null"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvKeywordsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No keywords blocked yet."
                android:textColor="#555577"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Emergency Reset -->
        <Button
            android:id="@+id/btnClearAll"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Clear All Blocked Items"
            android:textColor="#FF6B6B"
            android:textSize="14sp"
            android:backgroundTint="#1A0A0A"
            android:stateListAnimator="@null"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
